# Example .env file for AI SOC Platform
# Copy this file to infrastructure/.env and add your actual API keys

# VirusTotal API Key (get from https://www.virustotal.com/gui/my-apikey)
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API Key (get from https://www.abuseipdb.com/account/api)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# AlienVault OTX API Key (get from https://otx.alienvault.com/settings)
OTX_API_KEY=your_alienvault_otx_api_key_here

# MongoDB connection
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=ai_soc

# Redpanda connection
REDPANDA_BROKER=redpanda:9092
REDPANDA_TOPIC=wazuh-alerts

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Threat Intelligence API Keys
# Place your API keys below:
VIRUSTOTAL_API_KEY=your_virustotal_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
ALIENVAULT_OTX_API_KEY=your_alienvault_otx_key_here

# Dashboard
DASHBOARD_PORT=3000

# API Service
API_PORT=8000

# Other settings as needed
